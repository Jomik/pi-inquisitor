{
  "name": "pi-inquisitor",
  "version": "0.2.3",
  "packageManager": "npm@11.12.1",
  "description": "Interactive form tool for pi — radio and checkbox questions with AI-powered elaboration",
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-inquisitor.git"
  },
  "homepage": "https://github.com/Jomik/pi-inquisitor",
  "keywords": [
    "pi",
    "extension",
    "form",
    "interactive",
    "tui",
    "ask",
    "inquisitor"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typebox": "^1.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0",
    "typebox": "^1.0.0"
  }
}
